# Copy this file to ".env" in the same folder and replace <username> / <password>.
# .env is listed in .gitignore — do not commit it to GitHub.

# Password 含特殊字符时请做 URL 编码（如 @ → %40）
MONGODB_URI=mongodb+srv://<username>:<password>@webtechproject.uetatjw.mongodb.net/education_web_db?retryWrites=true&w=majority&appName=WebTechProject

# 若本机 Flask 已占用 5000，可改为 5001
PORT=5001
JWT_SECRET=replace-with-long-random-string
FRONTEND_ORIGIN=http://localhost:5173
